; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="PoM"
run/main_scene="uid://bupfyakwbpfo0"
config/features=PackedStringArray("4.5", "Forward Plus")

[autoload]

EventBus="*res://scripts/autoloads/event_bus.gd"
PriorityManager="*res://scripts/autoloads/priority_manager.gd"
ManaManager="*res://scripts/autoloads/mana_manager.gd"
ZoneManager="*res://scripts/autoloads/zone_manager.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/size/window_width_override=960
window/size/window_height_override=540
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"
